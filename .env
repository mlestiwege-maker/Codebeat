# Codebeat local environment overrides
# Voice
CODEBEAT_VOICE_SECONDS=4
CODEBEAT_PULSE_SOURCE=default
CODEBEAT_WHISPER_MODEL=tiny.en

# Face camera selection
# Use 0, 1, 2... depending on your webcam index
CODEBEAT_CAMERA_INDEX=0

# Face-only unlock mode: auto-scan on startup and hide passkey unlock controls
CODEBEAT_FACE_ONLY=1

# Optional owner-match threshold override (higher = stricter)
# CODEBEAT_FACE_THRESHOLD=0.88
