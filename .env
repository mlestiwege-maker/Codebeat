# Codebeat local environment overrides

# Safety Policy Configuration
# CODEBEAT_SAFETY_MODE: Enable/disable tool safety guards (1=on, 0=off)
CODEBEAT_SAFETY_MODE=1
# CODEBEAT_CONFIRM_RUN: Require confirmation before 'run <cmd>' execution (1=yes, 0=no)
CODEBEAT_CONFIRM_RUN=1
# CODEBEAT_CONFIRM_EXECUTE: Require confirmation before 'execute <cmd>' execution (1=yes, 0=no)
CODEBEAT_CONFIRM_EXECUTE=1
# CODEBEAT_REQUIRE_AUTH_CRITICAL: Require step-up auth for critical commands (1=yes, 0=no)
CODEBEAT_REQUIRE_AUTH_CRITICAL=1
# CODEBEAT_CRITICAL_PASSKEY: Optional passkey for `auth passkey <value>`
# CODEBEAT_CRITICAL_PASSKEY=change_me
# CODEBEAT_CRITICAL_AUTH_TTL: Seconds critical auth stays valid after successful auth
CODEBEAT_CRITICAL_AUTH_TTL=120

# Voice
CODEBEAT_VOICE_SECONDS=4
CODEBEAT_PULSE_SOURCE=default
CODEBEAT_WHISPER_MODEL=tiny.en

# Local AI / Ollama (opt-in)
CODEBEAT_OLLAMA_ENABLED=0
CODEBEAT_OLLAMA_BASE_URL=http://localhost:11434
CODEBEAT_OLLAMA_MODEL=llama3.2

# Comma-separated voice wake aliases stripped from transcripts
CODEBEAT_WAKE_ALIASES="codebeat,hey codebeat,hello codebeat,ok codebeat,okay codebeat,hello friend,dad's son"
# Seconds after wake phrase during which next speech is treated as command
CODEBEAT_WAKE_WINDOW_SECONDS=8
# Voice identity recognition mode (owner/non-owner)
CODEBEAT_VOICE_OWNER_MODE=1
# For critical voice-triggered commands, require owner voice match
CODEBEAT_VOICE_OWNER_FOR_CRITICAL=1
# Keep latest voice sample for owner identity checks
CODEBEAT_VOICE_SAVE_LAST=1
# Speak assistant responses aloud (1=on, 0=off)
CODEBEAT_VOICE_OUTPUT=1

# Text-to-Speech quality tuning
# engine: auto | piper | spd-say | espeak-ng | espeak
CODEBEAT_TTS_ENGINE=auto
# Voice id used by spd-say / espeak(-ng), e.g. en-us, en-gb
CODEBEAT_TTS_VOICE=en-us
# Speaking rate (80-260)
CODEBEAT_TTS_RATE=165
# Pitch (0-99), mainly for espeak backends
CODEBEAT_TTS_PITCH=45
# Optional high-quality Piper model path for natural voice
# CODEBEAT_TTS_PIPER_MODEL=/home/you/models/piper/en_US-amy-medium.onnx
# Optional Piper speaker id (-1 uses backend default)
CODEBEAT_TTS_PIPER_SPEAKER=0
# Max reply chars sent to TTS before truncation
CODEBEAT_TTS_MAX_CHARS=280
# Target chunk size for sentence-wise speech delivery
CODEBEAT_TTS_CHUNK_CHARS=150
# Pause between spoken chunks in milliseconds
CODEBEAT_TTS_PAUSE_MS=90

# Face camera selection
# Use 0, 1, 2... depending on your webcam index
CODEBEAT_CAMERA_INDEX=0

# Face-only unlock mode: auto-scan on startup and hide passkey unlock controls
CODEBEAT_FACE_ONLY=1

# Optional owner-match threshold override (higher = stricter)
# CODEBEAT_FACE_THRESHOLD=0.88
